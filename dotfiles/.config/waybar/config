{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 10,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["custom/gpu", "pulseaudio", "network", "power-profiles-daemon", "battery", "tray"],

  "clock": {
    "format": " {:%H:%M   %d}", // 24H
  },



  "hyprland/workspaces": {
    "persistent-workspaces": {
		  "*": 4
		},
  },



  "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "",
        "performance": "POWER",
        "balanced": "Mid",
        "power-saver": "Lite"
      }
    },
   
   "custom/gpu":{
	"format":"{}",
	"exec": "envycontrol -q"

},






  "pulseaudio": {
    "format": "  {volume}%",
    "format-muted": "󰖁 muted",
    "scroll-step": 5
  },

  "network": {
    "format-wifi": "  {signalStrength}%",
    "format-ethernet": "󰈀 wired",
    "format-disconnected": " no net"
  },

  "cpu": {
    "format": "  {usage}%"
  },

  "memory": {
    "format": "  {used:0.1f}G"
  },

  "battery": {
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ",
    "tooltip": true,
    "path": "/sys/class/power_supply/BAT0"
  },

  "tray": {
    "spacing": 10
  }
}
